{
  "name": "agent-do",
  "version": "0.3.0",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "agent-do": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "default": "./dist/src/testing/index.js"
    },
    "./stores": {
      "types": "./dist/src/stores.d.ts",
      "default": "./dist/src/stores.js"
    },
    "./stores/in-memory": {
      "types": "./dist/src/stores/in-memory.d.ts",
      "default": "./dist/src/stores/in-memory.js"
    },
    "./stores/filesystem": {
      "types": "./dist/src/stores/filesystem.d.ts",
      "default": "./dist/src/stores/filesystem.js"
    },
    "./prompts": {
      "types": "./dist/src/prompts/index.d.ts",
      "default": "./dist/src/prompts/index.js"
    },
    "./eval": {
      "types": "./dist/src/eval/index.d.ts",
      "default": "./dist/src/eval/index.js"
    }
  },
  "files": [
    "dist/src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "docs": "typedoc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "bash scripts/release.sh",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.168",
    "ignore": "^7.0.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
